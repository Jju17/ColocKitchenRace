rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ──────────────────────────────────────────────
    // Helper functions
    // ──────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    /// Only allow JPEG/PNG images under 1 MB.
    function isValidImage() {
      return request.resource.size < 1 * 1024 * 1024
          && request.resource.contentType.matches('image/(jpeg|png)');
    }

    // ──────────────────────────────────────────────
    // 1. CHALLENGE RESPONSE IMAGES
    //    Path: challenges/{challengeId}/responses/{responseId}.jpg
    //
    //  • Any signed-in user can READ (display in challenge tiles).
    //  • Any signed-in user can CREATE (submit a photo response).
    //  • UPDATE: the original uploader can re-submit.
    //  • DELETE: admin only (or Cloud Functions via Admin SDK).
    //
    //  LIMITATION: No cohouseId ownership check on create/update.
    //  The fileName is a UUID on iOS (not the cohouseId), making it
    //  impossible to reliably match the file name to the caller's
    //  cohouse via security rules alone. The Firestore-level
    //  challenge response document enforces submittedByAuthId, which
    //  provides the primary access control. A malicious user could
    //  overwrite another cohouse's image file but not the Firestore
    //  response document, so the impact is limited.
    // ──────────────────────────────────────────────
    match /challenges/{challengeId}/responses/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidImage();
      allow update: if isSignedIn() && isValidImage();
      allow delete: if isSignedIn() && isAdmin();
    }

    // ──────────────────────────────────────────────
    // 2. COHOUSE IMAGES
    //    Paths: cohouses/{cohouseId}/id_card.jpg
    //           cohouses/{cohouseId}/cover_image.jpg
    //
    //  • Any signed-in user can READ (cohouse display).
    //  • Any signed-in user can WRITE (upload during
    //    cohouse creation/editing — same approach as
    //    Firestore rules where membership check is relaxed).
    //  • DELETE: admin only (or Cloud Functions via Admin SDK
    //    during account/cohouse deletion).
    // ──────────────────────────────────────────────
    match /cohouses/{cohouseId}/{fileName} {
      allow read: if isSignedIn();
      // Only members of the cohouse (or admins) can upload/update images.
      allow create, update: if isSignedIn()
                            && isValidImage()
                            && (request.auth.token.cohouseId == cohouseId || isAdmin());
      allow delete: if isSignedIn() && isAdmin();
    }

    // ──────────────────────────────────────────────
    // CATCH-ALL: deny everything else
    // ──────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

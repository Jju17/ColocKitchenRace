rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // Helper functions
    // ──────────────────────────────────────────────

    /// The request comes from an authenticated user.
    function isSignedIn() {
      return request.auth != null;
    }

    /// The authenticated user's Firebase Auth UID.
    function authUid() {
      return request.auth.uid;
    }

    /// Super admin: full access to everything.
    function isSuperAdmin() {
      return request.auth.token.role == "super_admin"
             || request.auth.token.admin == true; // Legacy compat during migration
    }

    /// Edition admin: can create/manage their own editions.
    function isEditionAdmin() {
      return request.auth.token.role == "edition_admin";
    }

    /// Any admin role (super or edition).
    function isAnyAdmin() {
      return isSuperAdmin() || isEditionAdmin();
    }

    /// Legacy alias — kept so existing code referencing isAdmin() still works.
    function isAdmin() {
      return isSuperAdmin();
    }

    /// Check whether the caller is a member of the given cohouse.
    function isCohouseMember(cohouseId) {
      return isSignedIn()
        && request.auth.token.cohouseId == cohouseId;
    }

    /// Check whether the caller created this edition (for edition admin ownership).
    function isEditionOwner(gameId) {
      return isAnyAdmin()
        && get(/databases/$(database)/documents/ckrGames/$(gameId)).data.createdByAuthUid == authUid();
    }

    /// Check whether the caller can manage this edition.
    function canManageEdition(gameId) {
      return isSuperAdmin() || isEditionOwner(gameId);
    }

    // ──────────────────────────────────────────────
    // 1. USERS  (/users/{userId})
    // ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn()
                  && (resource.data.authId == authUid() || isSuperAdmin());

      allow create: if isSignedIn()
                    && request.resource.data.authId == authUid()
                    && request.resource.data.isAdmin == false;

      allow update: if isSignedIn()
                    && (
                      (resource.data.authId == authUid()
                       && request.resource.data.authId == resource.data.authId
                       && request.resource.data.isAdmin == resource.data.isAdmin
                       && request.resource.data.activeEditionId == resource.data.activeEditionId)
                      || isSuperAdmin()
                    );

      allow delete: if false;
    }

    // ──────────────────────────────────────────────
    // 2. COHOUSES  (/cohouses/{cohouseId})
    // ──────────────────────────────────────────────
    match /cohouses/{cohouseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn()
                    && isCohouseMember(cohouseId);
      allow delete: if false;

      match /users/{cohouseUserId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn()
                                      && isCohouseMember(cohouseId);
      }
    }

    // ──────────────────────────────────────────────
    // 3. CKR GAMES  (/ckrGames/{gameId})
    //
    //  Multi-edition rules:
    //  • Published games: any signed-in user can read
    //  • Draft games: only the creator or super admin
    //  • Create: any admin (super or edition)
    //  • Update/Delete: edition owner or super admin
    // ──────────────────────────────────────────────
    match /ckrGames/{gameId} {
      allow read: if isSignedIn()
                  && (
                    resource.data.status == "published"
                    || resource.data.createdByAuthUid == authUid()
                    || isSuperAdmin()
                  );

      allow create: if isSignedIn() && isAnyAdmin();

      allow update, delete: if isSignedIn() && canManageEdition(gameId);

      // ── Registrations subcollection ──
      match /registrations/{regId} {
        allow read: if isSignedIn()
                    && (isCohouseMember(regId) || canManageEdition(gameId));
        allow create, update, delete: if false;
      }

      // ── Challenges subcollection (NEW — scoped per edition) ──
      match /challenges/{challengeId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn() && canManageEdition(gameId);

        // ── Challenge Responses ──
        match /responses/{responseId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn()
                        && request.resource.data.submittedByAuthId == authUid();
          allow update: if isSignedIn()
                        && (canManageEdition(gameId) || resource.data.submittedByAuthId == authUid());
          allow delete: if false;
        }

        // ── Notification markers (Cloud Functions only) ──
        match /notifications/{notifId} {
          allow read: if false;
          allow write: if false;
        }
      }

      // ── Notification markers (Cloud Functions only) ──
      match /notifications/{notifId} {
        allow read: if false;
        allow write: if false;
      }
    }

    // ──────────────────────────────────────────────
    // 4. CHALLENGES (LEGACY — kept during migration)
    //
    //  Will be removed once all challenges are migrated
    //  to /ckrGames/{gameId}/challenges/{challengeId}
    // ──────────────────────────────────────────────
    match /challenges/{challengeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isSuperAdmin();

      match /responses/{responseId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
                      && request.resource.data.submittedByAuthId == authUid();
        allow update: if isSignedIn()
                      && (isSuperAdmin() || resource.data.submittedByAuthId == authUid());
        allow delete: if false;
      }

      match /notifications/{notifId} {
        allow read: if false;
        allow write: if false;
      }
    }

    // ──────────────────────────────────────────────
    // 5. NEWS  (/news/{newsId})
    // ──────────────────────────────────────────────
    match /news/{newsId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isSuperAdmin();
    }

    // ──────────────────────────────────────────────
    // 6. NOTIFICATION HISTORY  (/notificationHistory/{docId})
    // ──────────────────────────────────────────────
    match /notificationHistory/{docId} {
      allow read: if isSignedIn() && isAnyAdmin();
      allow create, update, delete: if false;
    }

    // ──────────────────────────────────────────────
    // COLLECTION GROUP QUERIES
    // ──────────────────────────────────────────────

    // Allow collectionGroup("responses") queries for signed-in users.
    match /{path=**}/responses/{responseId} {
      allow read: if isSignedIn();
    }

    // Allow collectionGroup("users") queries for signed-in users
    match /cohouses/{cohouseId}/users/{userId} {
      allow read: if isSignedIn();
    }

    // Allow collectionGroup("challenges") queries for signed-in users
    // (needed for checkChallengeSchedules Cloud Function scheduler)
    match /{path=**}/challenges/{challengeId} {
      allow read: if isSignedIn();
    }
  }
}
